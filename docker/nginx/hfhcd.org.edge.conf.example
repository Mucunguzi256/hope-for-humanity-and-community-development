# Host-level (edge) Nginx for hfhcd.org
#
# This file is intended for the server's main Nginx (outside Docker).
# It proxies to this project's Docker Nginx on 127.0.0.1:8082.
#
# If you use a different project port, update the upstream below.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream hfhcd_project_nginx {
    server 127.0.0.1:8082;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name hfhcd.org www.hfhcd.org;

    # Allow ACME challenge for Let's Encrypt.
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
        try_files $uri =404;
    }

    location / {
        return 301 https://hfhcd.org$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name hfhcd.org www.hfhcd.org;

    # Replace with your certificate paths.
    ssl_certificate /etc/letsencrypt/live/hfhcd.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hfhcd.org/privkey.pem;

    # Conservative TLS baseline.
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:20m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Optional OCSP stapling (requires trusted cert chain file if needed).
    ssl_stapling on;
    ssl_stapling_verify on;

    client_max_body_size 20m;

    # Security headers at edge.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Keep logs per site for easier triage.
    access_log /var/log/nginx/hfhcd.access.log;
    error_log /var/log/nginx/hfhcd.error.log warn;

    location / {
        proxy_pass http://hfhcd_project_nginx;

        proxy_http_version 1.1;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Upgrade $http_upgrade;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;

        proxy_read_timeout 120s;
        proxy_connect_timeout 30s;
        proxy_send_timeout 120s;

        proxy_buffering on;
        proxy_buffers 16 16k;
        proxy_buffer_size 16k;
    }

    # Let edge cache immutable static assets aggressively.
    location ~* \.(?:css|js|jpg|jpeg|gif|png|svg|ico|webp|woff|woff2|ttf)$ {
        proxy_pass http://hfhcd_project_nginx;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;

        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
    }
}
